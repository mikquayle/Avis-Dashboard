import json, os

DATA_FILE = "data/ratings.json"
PLACE_ID = "ChIJL7BqEp3FyIARP_QZDyQ5HJI"
TODAY = "2026-06-22"
REVIEWS_TODAY = 56  # manually confirmed
CURRENT_TOTAL = 9317  # from the Actions log

with open(DATA_FILE, "r") as f:
    data = json.load(f)

correct_baseline = CURRENT_TOTAL - REVIEWS_TODAY  # = 9261

# Fix all baseline keys for today
for key in list(data.get("daily_baselines", {}).keys()):
    if PLACE_ID in key and TODAY in key:
        old = data["daily_baselines"][key]
        data["daily_baselines"][key] = correct_baseline
        print("Fixed " + key + ": " + str(old) + " -> " + str(correct_baseline))

with open(DATA_FILE, "w") as f:
    json.dump(data, f, indent=2)

print("Done. Run scraper again to see updated counts.")
